{
    "name": "zwernemann/module-conversional-commerce",
    "description": "Conversational Commerce – replaces the Magento frontend with an AI-driven email channel (RAG + Anthropic Claude)",
    "type": "magento2-module",
    "version": "1.0.0",
    "require": {
        "php": ">=8.1",
        "magento/framework": "*",
        "magento/module-catalog": "*",
        "magento/module-customer": "*",
        "magento/module-sales": "*",
        "magento/module-backend": "*"
    },
    "autoload": {
        "files": ["registration.php"],
        "psr-4": {
            "Zwernemann\\ConversationalCommerce\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zwernemann\\ConversationalCommerce\\Test\\": "Test/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    }
}
