<script>
(function () {
    var actionUrl = '<?= $block->escapeJs($block->getAnonymizeUrl()) ?>';
    var formKey   = document.querySelector('input[name="form_key"]')
                    ? document.querySelector('input[name="form_key"]').value
                    : '';

    function showResult(message, success) {
        var el = document.getElementById('cc-gdpr-result');
        el.textContent = message;
        el.style.display = 'block';
        el.style.background = success ? '#d4edda' : '#f8d7da';
        el.style.border     = '1px solid ' + (success ? '#c3e6cb' : '#f5c6cb');
        el.style.color      = success ? '#155724' : '#721c24';
        window.scrollTo(0, el.offsetTop - 20);
    }

    function doRequest(params) {
        params.form_key = formKey;
        var body = Object.keys(params)
            .map(function(k){ return encodeURIComponent(k) + '=' + encodeURIComponent(params[k]); })
            .join('&');

        fetch(actionUrl, {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
            body: body
        })
        .then(function(r){ return r.json(); })
        .then(function(data){ showResult(data.message, data.success); })
        .catch(function(e){ showResult('Fehler: ' + e.message, false); });
    }

    document.getElementById('cc-gdpr-btn-email').addEventListener('click', function () {
        var email = document.getElementById('cc-gdpr-email').value.trim();
        if (!email) { showResult('<?= $block->escapeJs(__('Bitte E-Mail-Adresse eingeben.')) ?>', false); return; }
        if (!confirm('<?= $block->escapeJs(__('Alle Gesprächsdaten für diese E-Mail-Adresse unwiderruflich anonymisieren?')) ?>')) return;
        doRequest({email: email});
    });

    document.getElementById('cc-gdpr-btn-conv').addEventListener('click', function () {
        var id = document.getElementById('cc-gdpr-conv-id').value.trim();
        if (!id || parseInt(id) < 1) { showResult('<?= $block->escapeJs(__('Bitte eine gültige Konversations-ID eingeben.')) ?>', false); return; }
        if (!confirm('<?= $block->escapeJs(__('Diese Konversation unwiderruflich anonymisieren?')) ?>')) return;
        doRequest({conversation_id: id});
    });
}());
</script>
